# =============================================================================
# CodeAtlas AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Oracle Database (required for persistent memory) ---
ORACLE_PASSWORD=your_oracle_password
ORACLE_CONN_STRING=your_oracle_connection_string

# --- NVIDIA Embeddings (optional — skip if no embeddings needed) ---
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- API Key for MCP/REST authentication ---
CODEATLAS_API_KEY=your_api_key_here

# --- Firebase (optional — for telemetry & dashboard) ---
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Multi-Tenant Mode (set "true" to enable) ---
CODEATLAS_MULTI_TENANT=false
CODEATLAS_PROJECTS_ROOT=./tenants
