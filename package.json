{
  "name": "codeatlas",
  "displayName": "CodeAtlas",
  "description": "AI-powered code analysis with MCP server — gives AI assistants deep understanding of your codebase with persistent memory across conversations",
  "version": "1.6.2",
  "publisher": "giauphan",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/giauphan/CodeAtlas"
  },
  "license": "MIT",
  "bin": {
    "codeatlas-mcp": "dist/extension.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "code analysis",
    "graph",
    "visualization",
    "AI",
    "architecture"
  ],
  "badges": [],
  "galleryBanner": {
    "color": "#0a0a1a",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeatlas.analyzeProject",
        "title": "CodeAtlas: Analyze Project"
      },
      {
        "command": "codeatlas.openPanel",
        "title": "CodeAtlas: Open Insights Panel"
      }
    ],
    "configuration": {
      "title": "CodeAtlas",
      "properties": {
        "codeatlas.maxFiles": {
          "type": "number",
          "default": 5000,
          "description": "Maximum number of files to analyze (set to 0 for unlimited). All data is saved; UI display is controlled by initialNodeLimit."
        },
        "codeatlas.excludedDirectories": {
          "type": "array",
          "default": [
            "node_modules",
            "dist",
            "out",
            ".git",
            "__pycache__",
            ".venv",
            "vendor",
            "storage"
          ],
          "description": "Directories to exclude from analysis"
        },
        "codeatlas.excludedFiles": {
          "type": "array",
          "default": [
            "_ide_helper.php",
            "_ide_helper_models.php",
            ".phpstorm.meta.php"
          ],
          "description": "File names to exclude from analysis (e.g. generated stubs)"
        },
        "codeatlas.autoAnalyze": {
          "type": "boolean",
          "default": true,
          "description": "Automatically re-analyze on file save"
        },
        "codeatlas.fileExtensions": {
          "type": "array",
          "default": [
            ".ts",
            ".tsx",
            ".js",
            ".jsx",
            ".py",
            ".php"
          ],
          "description": "File extensions to include in analysis"
        },
        "codeatlas.graphPhysics": {
          "type": "string",
          "enum": [
            "relaxed",
            "default",
            "tight"
          ],
          "default": "default",
          "description": "Graph force simulation intensity"
        },
        "codeatlas.initialNodeLimit": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of nodes to load initially in the graph view. Set to 0 to load all nodes at once."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "test": "node --experimental-vm-modules node_modules/tsx/dist/cli.mjs src/test/analyzer.test.ts",
    "build:webview": "vite build",
    "build:extension": "node esbuild.js",
    "build": "npm run build:webview && npm run build:extension",
    "package": "npm run build && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.19.2",
    "eslint": "^8.47.0",
    "tsx": "^4.21.0",
    "typescript": "^5.1.6",
    "vite": "^4.4.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@typescript-eslint/typescript-estree": "^6.4.0",
    "lucide-react": "^0.268.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-2d": "^1.24.1",
    "zod": "^4.3.6"
  }
}
